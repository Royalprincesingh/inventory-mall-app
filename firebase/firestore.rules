rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global admin access
    match /{document=**} {
      allow read, write: if request.auth.token.email == "admin@mall.com";
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
        : "guest";
    }

    function isAdmin() {
      return isAuthenticated() && (
        getUserRole() == "super_admin" || 
        request.auth.token.email == "admin@mall.com"
      );
    }

    function isManager() {
      return isAuthenticated() && (
        getUserRole() == "store_manager" ||
        getUserRole() == "super_admin" ||
        request.auth.token.email == "admin@mall.com"
      );
    }

    function isStaff() {
      return isAuthenticated() && (
        getUserRole() == "staff" ||
        getUserRole() == "store_manager" ||
        getUserRole() == "super_admin"
      );
    }

    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // Products
    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Categories
    match /categories/{categoryId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Stores
    match /stores/{storeId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Suppliers
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Purchase Orders
    match /purchase_orders/{orderId} {
      allow read: if isAuthenticated();
      allow create, update: if isManager();
      allow delete: if isAdmin();
    }

    // Sales
    match /sales/{saleId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // Activity Logs
    match /activity_logs/{logId} {
      allow read: if isManager();
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Inventory Movements
    match /inventory_movements/{movementId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update: if isManager();
      allow delete: if isAdmin();
    }

    // Reports
    match /reports/{reportId} {
      allow read: if isManager();
      allow create: if isManager();
      allow delete: if isAdmin();
    }
  }
}
